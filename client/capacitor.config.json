{
  "appId": "com.myrescal.app",
  "appName": "MyResCal",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "backgroundColor": "#F5EDDC",
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#F5EDDC",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1F3C4A"
    },
    "Keyboard": {
      "resize": "body"
    }
  },
  "android": {
    "allowMixedContent": false
  }
}
